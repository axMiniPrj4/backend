# 오합지졸.io 백엔드 환경 변수 (.env로 복사 후 사용)
APP_NAME=ohapjijol.io
DEBUG=false

# MySQL 8 (로컬 설치 기준 — README의 DB/계정 생성 명령 참고)
DATABASE_URL=mysql+pymysql://ohap:ohap@localhost:3306/ohapjijol?charset=utf8mb4

# 1차 DB(위 DATABASE_URL) 연결 실패 시 우회할 2차 DB(RDS 등). 비우면 우회 없이 그대로 실패.
# 주의: 우회 대상 DB는 alembic upgrade head까지 스키마가 최신이어야 함(다르면 우회 후 다른 오류 발생).
# RDS_DATABASE_URL=mysql+pymysql://user:pass@your-rds-endpoint:3306/ohapjijol?charset=utf8mb4

# Redis — Refresh Token 저장 (비우면 인메모리 폴백, 개발 전용)
REDIS_URL=redis://localhost:6379/0

# JWT — 기준안: Access 30분 / Refresh 7일
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# 파일 업로드
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=52428800

# CORS (콤마 구분) — Vite 개발서버
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# AI (선택) — 없으면 가응답
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1

# SMTP — 아이디 찾기·비밀번호 재설정 메일 (비우면 메일 비활성, 비번 재설정은 화면 즉시 변경 폴백)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@gmail.com
# SMTP_PASSWORD=app-password
# SMTP_FROM=오합지졸 <noreply@invastor.pro>
# SMTP_USE_TLS=true
# FRONTEND_BASE_URL=https://invastor.pro
# PASSWORD_RESET_TOKEN_MINUTES=60

# 초기 SYSTEM_ADMIN 시드 기본값 (python -m scripts.seed_admin 인자 없을 때)
# FE .env 가 아니라 여기(백엔드)에만 둡니다. 시드 후 DB에 해시로 저장됩니다.
# ADMIN_LOGIN_ID=admin
# ADMIN_PASSWORD=admin1234!
# ADMIN_EMAIL=admin@ohapjijol.io

# 인프라 검증 대시보드 (모니터링 전용, SYSTEM_ADMIN만 조회 가능)
# 이 서버(EC2)에 CloudWatch/AutoScaling/ELB Describe* 읽기 권한을 가진 IAM Role이 붙어있어야 함
# (boto3가 IMDS를 통해 자동으로 자격증명을 가져오므로 Access Key는 여기에 넣지 않음)
# AWS_REGION=ap-northeast-2
# INFRA_ASG_NAME=ohapjijol-asg-v4
# INFRA_ALB_NAME=ohapjijol-alb-v4
# INFRA_TARGET_GROUP_ARN=arn:aws:elasticloadbalancing:ap-northeast-2:...:targetgroup/...
